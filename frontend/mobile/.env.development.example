# 局域网手机调试（可选，一般无需配置）
# 若自动识别 IP 失败，取消下行注释并改成你电脑的局域网 IP：
# VITE_API_BASE=http://10.0.1.103:8011/api
# VITE_AGENT_BASE=http://10.0.1.103:5001
# 文件/封面图服务（与 PC 端 uploads 一致，LAN 调试时改成可访问的地址）
VITE_FILE_URL_PREFIX=http://10.0.181.203:8080/uploads

# 钉钉绑定（后端环境变量，在启动 Spring Boot 前设置）
# DINGTALK_ENABLED=true
# DINGTALK_CLIENT_ID=你的ClientId
# DINGTALK_CLIENT_SECRET=你的ClientSecret
# DINGTALK_FRONTEND_ORIGIN=http://10.0.1.103:8011/m
# 钉钉开放平台「回调域名/redirect_uri」须登记为：
#   {上面地址}/#/settings/dingtalk/callback
