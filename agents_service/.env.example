# ── LLM (OpenAI 兼容 API) ──
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash           # 模型名可配置，当前用 v4-flash
LLM_TIMEOUT_MS=60000

# ── 视觉分析（通义千问 Qwen-VL / 阿里云百炼） ──
# 开通阿里云百炼后获取 DASHSCOPE_API_KEY
# 视觉模型参数，默认 qwen3-vl-plus
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=qwen3-vl-plus
VISION_TIMEOUT_MS=15000                # 单次视觉请求超时（毫秒）
VISION_RETRY_MAX=3                     # 失败重试次数
VISION_RETRY_BASE_DELAY=1              # 重试初始间隔（秒）
VISION_CIRCUIT_BREAKER_THRESHOLD=5     # 连续失败次数触发熔断

# ── MySQL 业务数据库 ──
# 格式: mysql+aiomysql://用户名:密码@主机:端口/库名
# 密码含 @ # ? 等特殊字符须 URL 编码，例如 pass@word → pass%40word
# 注意：不要添加 JDBC 专有参数（useUnicode, characterEncoding, useSSL 等），aiomysql 不支持
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/bs_exp_vue

# ── Checkpointer 独立数据库（LangGraph 持久化） ──
# 与业务库分离，可针对性做写入优化
CHECKPOINTER_URL=mysql+aiomysql://root:password@localhost:3306/bs_exp_checkpoints

# ── 服务 ──
HOST=0.0.0.0
PORT=5001
LOG_LEVEL=info
